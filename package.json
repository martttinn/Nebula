{
  "name": "nebula-studios",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "changes:entry:new": "node ./scripts/create-change-entry.js",
    "changes:group:new": "node ./scripts/create-change-group.js",
    "changes:validate": "node ./scripts/validate-change-log.js",
    "changes:index": "node ./scripts/build-change-log-index.js",
    "changes:sync": "npm run changes:validate && npm run changes:index",
    "video:dev": "remotion studio remotion/index.ts",
    "video:render": "remotion render remotion/index.ts",
    "video:still": "remotion still remotion/index.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:db:pull": "supabase db pull",
    "supabase:db:push": "supabase db push",
    "supabase:types:local": "supabase gen types typescript --local > lib/supabase/types.ts",
    "supabase:types:project": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF --schema public > lib/supabase/types.ts",
    "types:supabase": "npm run supabase:types:local"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "postprocessing": "^6.39.1",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tech-stack-icons": "^3.7.1",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.457",
    "@remotion/google-fonts": "4.0.457",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.180.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8",
    "remotion": "4.0.457",
    "supabase": "^2.98.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
